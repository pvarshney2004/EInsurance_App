@model List<EInsurance_App.ViewModels.Agent.CustomerListVM>

<div class="container mt-4">

    <h2>My Customers</h2>

    <div class="alert alert-info">
        <strong>Agent:</strong> @ViewBag.AgentName
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-warning text-center">
            <h5>No customers assigned</h5>
            <p>You don’t have any customers yet.</p>
        </div>
    }
    else
    {
        <table class="table table-bordered table-hover mt-3">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>Policies</th>
                    <th>Action</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var c in Model)
                {
                    <tr>
                        <td>@c.CustomerID</td>
                        <td>@c.FullName</td>
                        <td>@c.Email</td>
                        <td>@c.Phone</td>
                        <td>
                            <span class="badge bg-success">@c.PolicyCount</span>
                        </td>
                        <td>
                            <a asp-controller="Agent"
                                   asp-action="CustomerPolicies"
                                   asp-route-customerId="@c.CustomerID"
                                   class="btn btn-sm btn-primary">
                                View Policies
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

</div>