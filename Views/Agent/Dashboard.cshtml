<div class="ei-welcome">
    <div class="d-flex align-items-center gap-3">
        <div style="width:52px;height:52px;background:rgba(255,255,255,0.15);border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:1.4rem;">
            <i class="bi bi-person-badge"></i>
        </div>
        <div>
            <h3 class="mb-0 fw-bold">Agent Dashboard</h3>
            <p class="mb-0 mt-1" style="opacity:0.7;font-size:0.9rem;">Track your performance and customers</p>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card ei-stat-card text-center">
            <div class="card-body py-3">
                <p class="text-muted small mb-1">Total Customers</p>
                <div class="ei-stat-value" style="color:#0284c7;">@ViewBag.TotalCustomers</div>
                <small class="text-muted">Linked to you</small>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card" style="border-left:4px solid #10b981;">
            <div class="card-body text-center py-3">
                <p class="text-muted small mb-1">Policies Sold</p>
                <div class="ei-stat-value" style="color:#059669;">@ViewBag.TotalPolicies</div>
                <small class="text-muted">Total handled</small>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card" style="border-left:4px solid #f59e0b;">
            <div class="card-body text-center py-3">
                <p class="text-muted small mb-1">Total Commission</p>
                <div class="ei-stat-value" style="color:#d97706;">&#8377;@ViewBag.TotalCommission</div>
                <small class="text-muted">Your earnings</small>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-4">
        <div class="card ei-action-card h-100">
            <div class="card-body p-4">
                <div class="card-icon icon-amber"><i class="bi bi-calculator"></i></div>
                <h5 style="font-weight:600;color:#0f1f3d;">Calculate Premium</h5>
                <p class="text-muted small mb-3">Estimate premium for customers</p>
                <a asp-controller="Agent" asp-action="AvailablePolicies" class="btn btn-warning btn-sm px-4">Open</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card ei-action-card h-100">
            <div class="card-body p-4">
                <div class="card-icon icon-blue"><i class="bi bi-cash-coin"></i></div>
                <h5 style="font-weight:600;color:#0f1f3d;">Commission History</h5>
                <p class="text-muted small mb-3">View all your earnings</p>
                <a asp-controller="Agent" asp-action="CommissionHistory" class="btn btn-primary btn-sm px-4">View</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card ei-action-card h-100">
            <div class="card-body p-4">
                <div class="card-icon icon-green"><i class="bi bi-people"></i></div>
                <h5 style="font-weight:600;color:#0f1f3d;">My Customers</h5>
                <p class="text-muted small mb-3">View assigned customers</p>
                <a asp-controller="Agent" asp-action="Customers" class="btn btn-success btn-sm px-4">Open</a>
            </div>
        </div>
    </div>
</div>
