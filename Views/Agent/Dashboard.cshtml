<div class="container mt-4">

    <h2 class="text-center mb-4">Agent Dashboard</h2>

    <!-- STATS ROW -->
    <div class="row text-center mb-4">

        <div class="col-md-4 mb-3">
            <div class="card shadow border-0 bg-light">
                <div class="card-body">
                    <h5>Total Customers</h5>
                    <h3 class="text-primary">@ViewBag.TotalCustomers</h3>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card shadow border-0 bg-light">
                <div class="card-body">
                    <h5>Policies Sold</h5>
                    <h3 class="text-success">@ViewBag.TotalPolicies</h3>
                </div>
            </div>
        </div>

    </div>

    <!-- ACTION CARDS -->
    <div class="row">

        <!-- Calculate Premium -->
        <div class="col-md-4 mb-4">
            <div class="card shadow h-100 text-center">
                <div class="card-body">
                    <h5 class="card-title">Calculate Premium</h5>
                    <p class="card-text">Help customers estimate premium</p>

                    <a asp-controller="Agent"
                       asp-action="AvailablePolicies"
                       class="btn btn-warning">
                        Go
                    </a>
                </div>
            </div>
        </div>

    </div>

</div>