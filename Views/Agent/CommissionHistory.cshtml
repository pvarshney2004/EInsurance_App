@model List<EInsurance_App.ViewModels.Commission.CommissionHistoryVM>

<div class="ei-page-header">
    <div class="header-icon"><i class="bi bi-cash-coin"></i></div>
    <h2>Commission History</h2>
</div>

<div class="alert alert-info mb-3">
    <i class="bi bi-person-badge me-1"></i><strong>Agent:</strong> @ViewBag.AgentName
</div>

@if (!Model.Any())
{
    <div class="alert alert-warning text-center">
        <i class="bi bi-exclamation-circle me-1"></i>No commission records found yet.
    </div>
}
else
{
    <div class="ei-table table-responsive">
        <table class="table mb-0">
            <thead>
                <tr><th>ID</th><th>Policy</th><th>Customer</th><th>Premium</th><th>Commission</th><th>Date</th></tr>
            </thead>
            <tbody>
                @foreach (var c in Model)
                {
                    <tr>
                        <td><span class="badge" style="background:#e0f2fe;color:#0369a1;">#@c.CommissionID</span></td>
                        <td>@c.PolicyID</td>
                        <td><strong>@c.CustomerName</strong></td>
                        <td>&#8377;@c.Premium</td>
                        <td><span class="fw-bold" style="color:#059669;">&#8377;@c.CommissionAmount</span></td>
                        <td>@c.CreatedAt.ToString("dd MMM yyyy")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
