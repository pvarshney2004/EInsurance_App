@model List<EInsurance_App.ViewModels.Policy.AvailablePolicyVM>

<div class="ei-page-header">
    <div class="header-icon"><i class="bi bi-clipboard2-check"></i></div>
    <h2>Available Policies</h2>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info"><i class="bi bi-info-circle me-1"></i>No policies available.</div>
}

@foreach (var plan in Model)
{
    <div class="card mb-4">
        <div class="card-header ei-header-primary d-flex align-items-center gap-2">
            <i class="bi bi-clipboard2-data"></i>
            <h5 class="mb-0">@plan.PlanName</h5>
        </div>
        <div class="card-body p-3">
            <div class="row g-3">
                @foreach (var scheme in plan.Schemes)
                {
                    <div class="col-md-6">
                        <div class="p-3 rounded" style="background:#f8fafc;border:1.5px solid #e2e8f0;">
                            <h6 style="color:#0f1f3d;font-weight:600;">@scheme.SchemeName</h6>
                            <p class="text-muted small mb-3">@scheme.SchemeDetails</p>
                            <a asp-controller="Agent" asp-action="PremiumCalculator" asp-route-schemeId="@scheme.SchemeID"
                               class="btn btn-warning btn-sm">
                                <i class="bi bi-calculator me-1"></i>Calculate Premium
                            </a>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
}
