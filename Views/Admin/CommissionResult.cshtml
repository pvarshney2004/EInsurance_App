@model List<EInsurance_App.Models.Policy>

<div class="ei-page-header">
    <div class="header-icon"><i class="bi bi-cash-coin"></i></div>
    <h2>Commission Details</h2>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card ei-stat-card text-center">
            <div class="card-body py-3">
                <p class="text-muted small mb-1">Agent</p>
                <h6 class="fw-bold" style="color:#0f1f3d;">@ViewBag.AgentName</h6>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card" style="border-left:4px solid #10b981;" >
            <div class="card-body text-center py-3">
                <p class="text-muted small mb-1">Total Policies</p>
                <h3 class="fw-bold" style="color:#059669;">@ViewBag.TotalPolicies</h3>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card" style="border-left:4px solid #f59e0b;">
            <div class="card-body text-center py-3">
                <p class="text-muted small mb-1">Total Commission</p>
                <h3 class="fw-bold" style="color:#d97706;">&#8377;@ViewBag.TotalCommission</h3>
            </div>
        </div>
    </div>
</div>

@if (!Model.Any())
{
    <div class="alert alert-warning text-center">
        <i class="bi bi-exclamation-circle me-1"></i>No policies found for this agent.
    </div>
}
else
{
    <div class="ei-table table-responsive">
        <table class="table mb-0">
            <thead>
                <tr><th>Policy ID</th><th>Customer ID</th><th>Premium</th><th>Commission (10%)</th></tr>
            </thead>
            <tbody>
                @foreach (var p in Model)
                {
                    <tr>
                        <td><span class="badge" style="background:#e0f2fe;color:#0369a1;">#@p.PolicyID</span></td>
                        <td>@p.CustomerID</td>
                        <td>&#8377;@p.Premium</td>
                        <td><span class="fw-bold" style="color:#059669;">&#8377;@(p.Premium * 0.10m)</span></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
