@using EInsurance_App.ViewModels.Common
@using EInsurance_App.ViewModels.Policy
@model PagedResult<PolicyVM>

<div class="ei-page-header">
    <div class="header-icon"><i class="bi bi-search"></i></div>
    <h2>Search Customer Policies</h2>
</div>

<div class="card mb-4" style="border-radius:12px;border:none;box-shadow:0 2px 12px rgba(15,31,61,0.07);">
    <div class="card-body p-3">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-7">
                <label class="form-label">Customer Email</label>
                <input name="email" value="@ViewBag.Email" class="form-control" placeholder="Enter customer email..." />
            </div>
            <div class="col-md-3">
                <button class="btn btn-primary w-100"><i class="bi bi-search me-1"></i>Search</button>
            </div>
        </form>
    </div>
</div>

@if (Model != null && Model.Data.Any())
{
    <div class="alert alert-info mb-3">
        <i class="bi bi-person-circle me-1"></i><strong>Customer:</strong> @ViewBag.CustomerName
    </div>

    <div class="row g-3">
        @foreach (var policy in Model.Data)
        {
            <div class="col-md-6">
                <div class="card" style="border-left:4px solid #0284c7;">
                    <div class="card-body">

                        <!-- Header -->
                        <div class="d-flex justify-content-between mb-2">
                            <span class="badge" style="background:#e0f2fe;color:#0369a1;">
                                Policy #@policy.PolicyID
                            </span>

                            <!-- 🔥 Payment Status -->
                            @{
                                var totalPaid = policy.Payments?.Sum(p => p.Amount) ?? 0;
                                var remaining = policy.Premium - totalPaid;
                            }

                            @if (remaining <= 0)
                            {
                                <span class="badge bg-success">
                                    <i class="bi bi-check-circle me-1"></i>Fully Paid
                                </span>
                            }
                            else
                            {
                                <span class="badge" style="background:#fef3c7;color:#92400e;">
                                    <i class="bi bi-clock me-1"></i>₹@remaining Pending
                                </span>
                            }
                        </div>

                        <!-- Scheme -->
                        <p class="mb-1">
                            <strong>Scheme:</strong> @policy.SchemeName
                        </p>

                        <!-- Coverage -->
                        <p class="mb-1">
                            <span class="badge px-3 py-2" style="background:#ecfdf5;color:#065f46;">
                                @policy.CoverageAmountDisplay
                            </span>
                        </p>

                        <!-- Premium -->
                        <p class="mb-1">
                            <strong>Premium:</strong>
                            <span style="color:#059669;font-weight:600;">
                                &#8377;@policy.Premium
                            </span>
                        </p>

                        <!-- Issued Date -->
                        <p class="mb-2 text-muted small">
                            Issued on: @policy.DateIssued.ToString("dd MMM yyyy")
                        </p>

                        <!-- COLLAPSIBLE BUTTON -->
                        <button class="btn btn-sm btn-outline-primary w-100 mt-2"
                                data-bs-toggle="collapse"
                                data-bs-target="#payments-@policy.PolicyID">
                            <i class="bi bi-receipt me-1"></i> View Payments
                        </button>

                        <!-- COLLAPSIBLE CONTENT -->
                        <div id="payments-@policy.PolicyID" class="collapse mt-3">

                            <div class="p-3 rounded" style="background:#f8fafc;border:1px solid #e2e8f0;">

                                <!-- Summary -->
                                <div class="d-flex justify-content-between mb-2">
                                    <small class="text-muted">Total Paid:</small>
                                    <strong style="color:#059669;">₹@totalPaid</strong>
                                </div>
                                <div class="d-flex justify-content-between mb-3">
                                    <small class="text-muted">Remaining:</small>
                                    <strong style="color:#dc2626;">₹@remaining</strong>
                                </div>

                                @if (policy.Payments != null && policy.Payments.Any())
                                {
                                    <table class="table table-sm mb-0">
                                        <thead style="background:#f1f5f9;">
                                            <tr>
                                                <th>Amount</th>
                                                <th>Date</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var pay in policy.Payments)
                                            {
                                                <tr>
                                                    <td>
                                                        <span class="badge bg-success">
                                                            ₹@pay.Amount
                                                        </span>
                                                    </td>
                                                    <td>@pay.PaymentDate.ToString("dd MMM yyyy")</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                }
                                else
                                {
                                    <p class="text-muted small mb-0">
                                        <i class="bi bi-info-circle me-1"></i>No payments yet.
                                    </p>
                                }

                            </div>
                        </div>

                    </div>
                </div>
            </div>
        }
    </div>

    <nav class="mt-4">
        <ul class="pagination justify-content-center">
            <li class="page-item @(Model.PageNumber == 1 ? "disabled" : "")">
                <a class="page-link" asp-route-email="@ViewBag.Email" asp-route-page="@(Model.PageNumber - 1)">Prev</a>
            </li>
            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                    <a class="page-link" asp-route-email="@ViewBag.Email" asp-route-page="@i">@i</a>
                </li>
            }
            <li class="page-item @(Model.PageNumber == Model.TotalPages ? "disabled" : "")">
                <a class="page-link" asp-route-email="@ViewBag.Email" asp-route-page="@(Model.PageNumber + 1)">Next</a>
            </li>
        </ul>
    </nav>
    <p class="text-center text-muted small">Page @Model.PageNumber of @Model.TotalPages</p>
}
@if (ViewBag.Error != null && ViewBag.CustomerFound == false)
{
    <div class="alert alert-danger text-center">
        <i class="bi bi-exclamation-triangle me-1"></i>@ViewBag.Error
    </div>
}
else if (ViewBag.HasSearched == true && ViewBag.CustomerFound == true && (Model == null || !Model.Data.Any()))
{
    <div class="alert alert-info text-center">
        <i class="bi bi-info-circle me-1"></i>
        No policies found for this customer.
    </div>
}