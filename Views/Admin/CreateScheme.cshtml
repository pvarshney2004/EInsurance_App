@model EInsurance_App.Models.Scheme

<div class="ei-page-header">
    <div class="header-icon"><i class="bi bi-plus-circle"></i></div>
    <h2>Create Scheme</h2>
</div>

<div class="card" style="max-width:560px;border-radius:14px;border:none;box-shadow:0 4px 20px rgba(15,31,61,0.09);">
    <div class="card-body p-4">
        <form asp-action="CreateScheme" method="post">
            <input type="hidden" asp-for="PlanID" />
            <div class="mb-3">
                <label>Scheme Name</label>
                <input asp-for="SchemeName" class="form-control" placeholder="Enter scheme name" />
            </div>
            <div class="mb-4">
                <label>Details</label>
                <input asp-for="SchemeDetails" class="form-control" placeholder="Enter scheme details" />
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-success"><i class="bi bi-check-lg me-1"></i>Create</button>
                <a asp-action="Plans" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
