@model EInsurance_App.Models.InsuranceAgent

<div class="ei-page-header">
    <div class="header-icon"><i class="bi bi-pencil-square"></i></div>
    <h2>Edit Agent</h2>
</div>

<div class="card" style="max-width:560px;border-radius:14px;border:none;box-shadow:0 4px 20px rgba(15,31,61,0.09);">
    <div class="card-body p-4">
        <form asp-action="EditAgent" method="post">
            <input type="hidden" asp-for="AgentID" />
            <div class="mb-3">
                <label>Username</label>
                <input asp-for="Username" class="form-control" />
                <span asp-validation-for="Username" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label>Email</label>
                <input asp-for="Email" class="form-control" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>
            <div class="mb-4">
                <label>Full Name</label>
                <input asp-for="FullName" class="form-control" />
                <span asp-validation-for="FullName" class="text-danger small"></span>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-success"><i class="bi bi-check-lg me-1"></i>Update</button>
                <a asp-action="Agents" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
