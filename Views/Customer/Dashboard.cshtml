<div class="container mt-4">

    ```
    <!-- Welcome Section -->
    <div class="p-4 mb-4 bg-light rounded shadow-sm">
        <h2 class="mb-1">Welcome</h2>
        <p class="text-muted mb-0">
            Manage your policies, track payments, and explore new insurance plans.
        </p>
    </div>

    <!-- Stats Section -->
    <div class="row mb-4">

        <!-- Total Policies -->
        <div class="col-md-4">
            <div class="card text-center shadow border-0">
                <div class="card-body">
                    <h6 class="text-muted">Total Policies</h6>
                    <h2 class="text-primary">@ViewBag.TotalPolicies</h2>
                </div>
            </div>
        </div>

        <!-- Total Payments -->
        <div class="col-md-4">
            <div class="card text-center shadow border-0">
                <div class="card-body">
                    <h6 class="text-muted">Payments Made</h6>
                    <h2 class="text-success">@ViewBag.TotalPayments</h2>
                </div>
            </div>
        </div>

        <!-- Total Amount -->
        <div class="col-md-4">
            <div class="card text-center shadow border-0">
                <div class="card-body">
                    <h6 class="text-muted">Total Amount Paid</h6>
                    <h2 class="text-dark">₹@ViewBag.TotalAmount</h2>
                </div>
            </div>
        </div>

    </div>

    <!-- Empty State (Optional UX Improvement) -->
    @if (ViewBag.TotalPolicies == 0)
    {
        <div class="alert alert-info text-center">
            You don’t have any policies yet. Start by purchasing one!
        </div>
    }

    <!-- Action Cards -->
    <div class="row">

        <!-- My Policies -->
        <div class="col-md-6 mb-4">
            <div class="card shadow h-100 text-center border-0">
                <div class="card-body">
                    <div class="mb-3">
                        <i class="bi bi-file-earmark-text fs-1 text-primary"></i>
                    </div>
                    <h5 class="card-title">My Policies</h5>
                    <p class="card-text">
                        View your active policies and payment history.
                    </p>

                    <a asp-controller="Customer" asp-action="MyPolicies"
                           class="btn btn-primary">
                        View Policies
                    </a>
                </div>
            </div>
        </div>

        <!-- Buy Policy -->
        <div class="col-md-6 mb-4">
            <div class="card shadow h-100 text-center border-0">
                <div class="card-body">
                    <div class="mb-3">
                        <i class="bi bi-cart-plus fs-1 text-success"></i>
                    </div>
                    <h5 class="card-title">Buy Policy</h5>
                    <p class="card-text">
                        Explore available insurance plans and purchase new policies.
                    </p>

                    <a asp-controller="Customer" asp-action="AvailablePolicies"
                           class="btn btn-success">
                        Browse Policies
                    </a>
                </div>
            </div>
        </div>

    </div>
    ```

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
