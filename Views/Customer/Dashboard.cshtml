@if (TempData["Success"] != null)
{
    <div class="alert alert-success text-center">@TempData["Success"]</div>
}

<div class="ei-welcome">
    <div class="d-flex align-items-center gap-3">
        <div style="width:52px;height:52px;background:rgba(255,255,255,0.15);border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:1.4rem;">
            <i class="bi bi-person-circle"></i>
        </div>
        <div>
            <h3 class="mb-0 fw-bold">Welcome Back!</h3>
            <p class="mb-0 mt-1" style="opacity:0.7;font-size:0.9rem;">Manage your policies, track payments, and explore new plans.</p>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card ei-stat-card text-center">
            <div class="card-body py-3">
                <p class="text-muted small mb-1">Total Policies</p>
                <div class="ei-stat-value" style="color:#0284c7;">@ViewBag.TotalPolicies</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card" style="border-left:4px solid #10b981;">
            <div class="card-body text-center py-3">
                <p class="text-muted small mb-1">Payments Made</p>
                <div class="ei-stat-value" style="color:#059669;">@ViewBag.TotalPayments</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card" style="border-left:4px solid #f59e0b;">
            <div class="card-body text-center py-3">
                <p class="text-muted small mb-1">Total Amount Paid</p>
                <div class="ei-stat-value" style="color:#d97706;">&#8377;@ViewBag.TotalAmount</div>
            </div>
        </div>
    </div>
</div>

@if (ViewBag.TotalPolicies == 0)
{
    <div class="alert alert-info text-center mb-4">
        <i class="bi bi-lightbulb me-1"></i>You don't have any policies yet. Start by purchasing one!
    </div>
}

<div class="row g-4">
    <div class="col-md-4">
        <div class="card ei-action-card h-100">
            <div class="card-body p-4">
                <div class="card-icon icon-blue"><i class="bi bi-file-earmark-text"></i></div>
                <h5 style="font-weight:600;color:#0f1f3d;">My Policies</h5>
                <p class="text-muted small mb-3">View your active policies and payment history.</p>
                <a asp-controller="Customer" asp-action="MyPolicies" class="btn btn-primary btn-sm px-4">View Policies</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card ei-action-card h-100">
            <div class="card-body p-4">
                <div class="card-icon icon-green"><i class="bi bi-cart-plus"></i></div>
                <h5 style="font-weight:600;color:#0f1f3d;">Buy Policy</h5>
                <p class="text-muted small mb-3">Explore insurance plans and purchase new policies.</p>
                <a asp-controller="Customer" asp-action="AvailablePolicies" class="btn btn-success btn-sm px-4">Browse</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card ei-action-card h-100">
            <div class="card-body p-4">
                <div class="card-icon icon-teal"><i class="bi bi-person-lines-fill"></i></div>
                <h5 style="font-weight:600;color:#0f1f3d;">Assign Agent</h5>
                <p class="text-muted small mb-3">Link with an insurance agent for personalized support.</p>
                <a asp-action="SelectAgent" class="btn btn-info btn-sm px-4">Link Agent</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
