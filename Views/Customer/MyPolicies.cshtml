@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

@using EInsurance_App.ViewModels.Policy
@model CustomerPolicyVM

<div class="ei-page-header">
    <div class="header-icon"><i class="bi bi-file-earmark-text"></i></div>
    <h2>@Model.CustomerName &mdash; My Policies</h2>
</div>

@if (!Model.Policies.Any())
{
    <div class="alert alert-info text-center">
        <i class="bi bi-info-circle me-1"></i>No policies found. Start by purchasing one!
    </div>
}

@foreach (var policy in Model.Policies)
{
    <div class="card mb-4">
        <div class="ei-policy-header">
            <div class="d-flex align-items-center gap-2">
                <i class="bi bi-file-earmark-check"></i>
                <h5 class="mb-0 fw-bold">Policy #@policy.PolicyID</h5>
            </div>
            @if (policy.RemainingAmount == 0)
            {
                <span class="badge bg-success px-3 py-2"><i class="bi bi-check-circle me-1"></i>Fully Paid</span>
            }
            else
            {
                <span class="badge py-2 px-3" style="background:#fef3c7;color:#92400e;">
                    <i class="bi bi-clock me-1"></i>&#8377;@policy.RemainingAmount Pending
                </span>
            }
        </div>

        <div class="card-body p-4">
            <div class="row mb-4 g-3">
                <div class="row mb-4 g-3">

                    <!-- Scheme -->
                    <div class="col-md-3">
                        <div class="p-3 rounded" style="background:#f8fafc;border:1.5px solid #e2e8f0;">
                            <p class="text-muted small mb-1">Scheme</p>
                            <p class="fw-bold mb-0" style="color:#0f1f3d;">@policy.SchemeName</p>
                        </div>
                    </div>

                    <!-- Coverage -->
                    <div class="col-md-3">
                        <div class="p-3 rounded" style="background:#ecfeff;border:1.5px solid #67e8f9;">
                            <p class="fw-bold mb-0" style="color:#0891b2;">
                                @policy.CoverageAmountDisplay
                            </p>
                        </div>
                    </div>

                    <!-- Premium -->
                    <div class="col-md-3">
                        <div class="p-3 rounded" style="background:#f0fdf4;border:1.5px solid #bbf7d0;">
                            <p class="text-muted small mb-1">Total Premium</p>
                            <p class="fw-bold mb-0" style="color:#059669;">&#8377;@policy.Premium</p>
                        </div>
                    </div>

                    <!-- Date -->
                    <div class="col-md-3">
                        <div class="p-3 rounded" style="background:#f8fafc;border:1.5px solid #e2e8f0;">
                            <p class="text-muted small mb-1">Issued Date</p>
                            <p class="fw-bold mb-0" style="color:#0f1f3d;">
                                @policy.DateIssued.ToString("dd MMM yyyy")
                            </p>
                        </div>
                    </div>

                </div>
            </div>

            <h6 class="mb-3 fw-bold" style="color:#0f1f3d;"><i class="bi bi-receipt me-1"></i>Payments</h6>

            @if (policy.Payments.Any())
            {
                <div class="ei-table table-responsive mb-3">
                    <table class="table mb-0">
                        <thead>
                            <tr><th>Amount</th><th>Date</th><th>Invoice</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var pay in policy.Payments)
                            {
                                <tr>
                                    <td><span class="badge bg-success px-3 py-2">&#8377;@pay.Amount</span></td>
                                    <td>@pay.PaymentDate.ToString("dd MMM yyyy")</td>
                                    <td>
                                        <a asp-action="GenerateInvoice" asp-route-paymentId="@pay.PaymentID"
                                           class="btn btn-outline-primary btn-sm">
                                            <i class="bi bi-download me-1"></i>Invoice
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-muted small"><i class="bi bi-info-circle me-1"></i>No payments yet.</p>
            }

            <div class="d-flex justify-content-between align-items-center pt-2 border-top">
                <div>
                    <span class="text-muted small">Remaining: </span>
                    <span class="badge py-2 px-3" style="background:#fef3c7;color:#92400e;">&#8377;@policy.RemainingAmount</span>
                </div>
                @if (policy.RemainingAmount > 0)
                {
                    <a asp-action="MakePayment" asp-route-policyId="@policy.PolicyID" class="btn btn-success btn-sm">
                        <i class="bi bi-credit-card me-1"></i>Pay Premium
                    </a>
                }
            </div>
        </div>
    </div>
}
