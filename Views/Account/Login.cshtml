@using EInsurance_App.ViewModels.Auth
@model LoginVM

<div class="container-fluid">
    <div class="row min-vh-100">

        <!-- LEFT SIDE-->
        <div class="col-md-6 d-none d-md-flex align-items-center justify-content-center position-relative rounded-3"
             style="background:linear-gradient(135deg,#0f1f3d,#1a3260);color:white;overflow:hidden;">

            <div style="position:absolute;width:400px;height:400px;background:#06b6d4;opacity:0.15;
            border-radius:50%;top:-100px;left:-100px;filter:blur(80px);"></div>

            <div style="max-width:440px;padding:2.5rem;z-index:2;">
                <div class="mb-4">
                    <div style="width:70px;height:70px;border-radius:18px;
                        background:linear-gradient(135deg,#0284c7,#06b6d4);
                        display:flex;align-items:center;justify-content:center;
                        font-size:2rem;">
                        <i class="bi bi-shield-check"></i>
                    </div>
                </div>

                <h1 style="font-weight:700;line-height:1.25;">
                    Insurance that feels <span style="color:#06b6d4;">simple</span>,
                    fast & secure
                </h1>

                <p class="mt-3" style="color:rgba(255,255,255,0.75);font-size:0.95rem;">
                    Manage policies, calculate premiums, and secure your future —
                    all in one intelligent platform.
                </p>
            </div>
        </div>

        <!-- RIGHT SIDE -->
        <div class="col-md-6 d-flex align-items-center justify-content-center">
            <div style="width:100%;max-width:420px;">

                <div class="text-center mb-4">
                    <div style="width:64px;height:64px;background:linear-gradient(135deg,#0284c7,#06b6d4);
                        border-radius:16px;display:flex;align-items:center;justify-content:center;
                        margin:0 auto 1rem;font-size:1.8rem;color:#fff;">
                        <i class="bi bi-shield-check"></i>
                    </div>
                    <h2 style="font-weight:700;color:#0f1f3d;">Welcome back</h2>
                    <p class="text-muted" style="font-size:0.9rem;">Sign in to your account</p>
                </div>

                <div class="card" style="border-radius:16px;border:none;box-shadow:0 8px 40px rgba(15,31,61,0.12);">
                    <div class="card-body p-4">

                        <form asp-action="Login" method="post">
                            @Html.AntiForgeryToken()

                            <!-- MODEL ERROR (Invalid credentials) -->
                            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2"></div>

                            <!-- EMAIL -->
                            <div class="mb-3">
                                <label class="form-label">Email address</label>
                                <div class="input-group">
                                    <span class="input-group-text"
                                          style="background:#f8fafc;border:1.5px solid #e2e8f0;border-right:none;">
                                        <i class="bi bi-envelope"></i>
                                    </span>
                                    <input asp-for="Email" class="form-control"
                                           placeholder="you@example.com"
                                           style="border-left:none;" />
                                </div>
                                <span asp-validation-for="Email" class="text-danger small mt-1 d-block"></span>
                            </div>

                            <!-- PASSWORD -->
                            <div class="mb-4">
                                <label class="form-label">Password</label>
                                <div class="input-group">
                                    <span class="input-group-text"
                                          style="background:#f8fafc;border:1.5px solid #e2e8f0;border-right:none;">
                                        <i class="bi bi-lock"></i>
                                    </span>
                                    <input asp-for="Password" type="password"
                                           class="form-control"
                                           placeholder="••••••••"
                                           style="border-left:none;" />
                                </div>
                                <span asp-validation-for="Password" class="text-danger small mt-1 d-block"></span>
                            </div>

                            <!-- BUTTON -->
                            <button class="btn btn-primary w-100 py-2" style="font-weight:600;">
                                <i class="bi bi-box-arrow-in-right me-1"></i> Sign In
                            </button>

                            <!-- LINK -->
                            <div class="text-center mt-3">
                                <small class="text-muted">
                                    Don't have an account?
                                    <a asp-action="Register" style="color:#0284c7;font-weight:500;">
                                        Create one
                                    </a>
                                </small>
                            </div>

                        </form>

                    </div>
                </div>

            </div>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}