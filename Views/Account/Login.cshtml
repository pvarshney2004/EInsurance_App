@using EInsurance_App.ViewModels.Auth
@model LoginVM

<div class="container-fluid">
    <div class="row min-vh-100">

        <!-- LEFT SIDE (Branding / Description) -->
        <div class="col-md-6 d-none d-md-flex align-items-center justify-content-center position-relative rounded-3"
             style="background:linear-gradient(135deg,#0f1f3d,#1a3260);color:white;overflow:hidden;">

            <!-- Subtle background glow -->
            <div style="position:absolute;width:400px;height:400px;background:#06b6d4;opacity:0.15;
            border-radius:50%;top:-100px;left:-100px;filter:blur(80px);"></div>

            <div style="max-width:440px;padding:2.5rem;z-index:2;">

                <!-- Logo -->
                <div class="mb-4">
                    <div style="width:70px;height:70px;border-radius:18px;
                        background:linear-gradient(135deg,#0284c7,#06b6d4);
                        display:flex;align-items:center;justify-content:center;
                        font-size:2rem;box-shadow:0 8px 25px rgba(6,182,212,0.4);">
                        <i class="bi bi-shield-check"></i>
                    </div>
                </div>

                <!-- Headline -->
                <h1 style="font-weight:700;line-height:1.25;">
                    Insurance that feels <span style="color:#06b6d4;">simple</span>,
                    fast & secure
                </h1>

                <!-- Tagline -->
                <p class="mt-3" style="color:rgba(255,255,255,0.75);font-size:0.95rem;">
                    Manage policies, calculate premiums, and secure your future —
                    all in one intelligent platform built for modern users.
                </p>

                <!-- Feature Cards -->
                <div class="mt-4">

                    <div class="d-flex align-items-start mb-3 gap-3">
                        <div style="width:40px;height:40px;border-radius:10px;background:#1e3a5f;
                            display:flex;align-items:center;justify-content:center;color:#06b6d4;">
                            <i class="bi bi-graph-up"></i>
                        </div>
                        <div>
                            <div style="font-weight:600;">Smart Premium Calculation</div>
                            <small style="color:rgba(255,255,255,0.6);">
                                Get instant, transparent pricing tailored to you
                            </small>
                        </div>
                    </div>

                    <div class="d-flex align-items-start mb-3 gap-3">
                        <div style="width:40px;height:40px;border-radius:10px;background:#1e3a5f;
                            display:flex;align-items:center;justify-content:center;color:#10b981;">
                            <i class="bi bi-shield-lock"></i>
                        </div>
                        <div>
                            <div style="font-weight:600;">Secure & Reliable</div>
                            <small style="color:rgba(255,255,255,0.6);">
                                Your data and policies are always protected
                            </small>
                        </div>
                    </div>

                    <div class="d-flex align-items-start gap-3">
                        <div style="width:40px;height:40px;border-radius:10px;background:#1e3a5f;
                            display:flex;align-items:center;justify-content:center;color:#f59e0b;">
                            <i class="bi bi-lightning-charge"></i>
                        </div>
                        <div>
                            <div style="font-weight:600;">Fast & Hassle-Free</div>
                            <small style="color:rgba(255,255,255,0.6);">
                                Buy and manage policies in just a few clicks
                            </small>
                        </div>
                    </div>

                </div>

                <!-- Trust indicator -->
                <div class="mt-5 d-flex align-items-center gap-2" style="color:rgba(255,255,255,0.6);font-size:0.85rem;">
                    <i class="bi bi-stars"></i>
                    Trusted by 10,000+ users
                </div>

            </div>
        </div>

        <!-- RIGHT SIDE (Login Form) -->
        <div class="col-md-6 d-flex align-items-center justify-content-center">
            <div style="width:100%;max-width:420px;">

                <div class="text-center mb-4">
                    <div style="width:64px;height:64px;background:linear-gradient(135deg,#0284c7,#06b6d4);border-radius:16px;display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;font-size:1.8rem;color:#fff;">
                        <i class="bi bi-shield-check"></i>
                    </div>
                    <h2 style="font-weight:700;color:#0f1f3d;">Welcome back</h2>
                    <p class="text-muted" style="font-size:0.9rem;">Sign in to your EInsurance account</p>
                </div>

                <div class="card" style="border-radius:16px;border:none;box-shadow:0 8px 40px rgba(15,31,61,0.12);">
                    <div class="card-body p-4">

                        <form asp-action="Login" method="post">

                            <div asp-validation-summary="All" class="text-danger small mb-3"></div>

                            <div class="mb-3">
                                <label class="form-label">Email address</label>
                                <div class="input-group">
                                    <span class="input-group-text" style="background:#f8fafc;border:1.5px solid #e2e8f0;border-right:none;border-radius:8px 0 0 8px;">
                                        <i class="bi bi-envelope"></i>
                                    </span>
                                    <input asp-for="Email" class="form-control" placeholder="you@example.com"
                                           style="border-left:none;border-radius:0 8px 8px 0;" />
                                </div>
                            </div>

                            <div class="mb-4">
                                <label class="form-label">Password</label>
                                <div class="input-group">
                                    <span class="input-group-text" style="background:#f8fafc;border:1.5px solid #e2e8f0;border-right:none;border-radius:8px 0 0 8px;">
                                        <i class="bi bi-lock"></i>
                                    </span>
                                    <input asp-for="Password" type="password" class="form-control"
                                           placeholder="••••••••"
                                           style="border-left:none;border-radius:0 8px 8px 0;" />
                                </div>
                            </div>

                            <button class="btn btn-primary w-100 py-2" style="font-weight:600;">
                                <i class="bi bi-box-arrow-in-right me-1"></i> Sign In
                            </button>

                            <div class="text-center mt-3">
                                <small class="text-muted">
                                    Don't have an account?
                                    <a asp-action="Register" style="color:#0284c7;font-weight:500;">Create one</a>
                                </small>
                            </div>

                        </form>

                    </div>
                </div>

            </div>
        </div>

    </div>
</div>