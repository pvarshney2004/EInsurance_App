@{
    var role = Context.Session.GetString("Role");
    var email = Context.Session.GetString("UserEmail");
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EInsurance</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/EInsurance_App.styles.css" asp-append-version="true" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
</head>

<body class="d-flex flex-column min-vh-100">

    <!-- NAVBAR -->
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
            <div class="container-fluid">

                <!-- Logo -->
                <a class="navbar-brand fw-bold" href="@Url.Action("RedirectDashboard", "Account")">
                    <i class="bi bi-shield-check"></i> EInsurance
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarContent">

                    <!-- LEFT SIDE -->
                    <ul class="navbar-nav me-auto">

                        @if (role == "Customer")
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Customer" asp-action="Dashboard">Dashboard</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Customer" asp-action="MyPolicies">My Policies</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Customer" asp-action="AvailablePolicies">Buy Policy</a>
                            </li>
                        }

                        @if (role == "Agent")
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Agent" asp-action="Dashboard">Dashboard</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Agent" asp-action="Customers">Customers</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Agent" asp-action="CommissionHistory">Commission</a>
                            </li>
                        }

                        @if (role == "Admin")
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Admin" asp-action="Dashboard">Dashboard</a>
                            </li>
                        }

                        @if (role == "Employee")
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Employee" asp-action="Dashboard">Dashboard</a>
                            </li>
                        }

                    </ul>

                    <!-- RIGHT SIDE -->
                    <ul class="navbar-nav ms-auto">

                        @if (!string.IsNullOrEmpty(email))
                        {
                            <li class="nav-item">
                                <span class="nav-link text-light">
                                    <i class="bi bi-person-circle"></i> @email
                                </span>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-danger"
                                       asp-controller="Account"
                                       asp-action="Logout">
                                    <i class="bi bi-box-arrow-right"></i> Logout
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link"
                                       asp-controller="Account"
                                       asp-action="Login">
                                    Login
                                </a>
                            </li>
                        }

                    </ul>

                </div>
            </div>
        </nav>
    </header>

    <!-- MAIN CONTENT -->
    <div class="container mt-4 flex-grow-1">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <!-- FOOTER -->
    <footer class="bg-light text-muted mt-auto">
        <div class="container text-center py-3">
            © 2026 - EInsurance System
        </div>
    </footer>

    <!-- SCRIPTS -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>