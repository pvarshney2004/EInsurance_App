@{
    var role = Context.Session.GetString("Role");
    var email = Context.Session.GetString("UserEmail");
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EInsurance</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/EInsurance_App.styles.css" asp-append-version="true" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <style>
        :root {
            --ei-navy: #0f1f3d;
            --ei-navy-light: #1a3260;
            --ei-teal: #0ea5e9;
            --ei-teal-dark: #0284c7;
            --ei-accent: #06b6d4;
            --ei-success: #10b981;
            --ei-warning: #f59e0b;
            --ei-danger: #ef4444;
            --ei-surface: #f8fafc;
            --ei-card-border: #e2e8f0;
            --ei-text-muted: #64748b;
            --ei-radius: 12px;
            --ei-shadow: 0 4px 20px rgba(15,31,61,0.08);
            --ei-shadow-hover: 0 8px 32px rgba(15,31,61,0.14);
        }

        * { box-sizing: border-box; }

        html, body { height: 100%; }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--ei-surface);
            color: #1e293b;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
            padding-top: 80px;
        }

        body > .container {
            flex: 1 0 auto;
        }


        /* NAVBAR */
        .ei-navbar {
            background: linear-gradient(135deg, var(--ei-navy) 0%, var(--ei-navy-light) 100%);
            padding: 0 1.5rem;
            box-shadow: 0 2px 20px rgba(15,31,61,0.25);
            min-height: 64px;
            position: fixed;   
            top: 0;            
            left: 0;           
            width: 100%;       
            z-index: 1000;     
        }
        .ei-navbar .navbar-brand {
            font-size: 1.3rem; font-weight: 700; color: #fff !important; letter-spacing: -0.3px;
        }
        .ei-navbar .navbar-brand i { color: var(--ei-teal); margin-right: 6px; }
        .ei-navbar .nav-link {
            color: rgba(255,255,255,0.75) !important; font-weight: 500; font-size: 0.9rem;
            padding: 0.5rem 0.9rem !important; border-radius: 8px; transition: all 0.2s;
        }
        .ei-navbar .nav-link:hover { color: #fff !important; background: rgba(255,255,255,0.1); }
        .ei-navbar .nav-link.text-danger { color: #fca5a5 !important; }
        .ei-navbar .nav-link.text-danger:hover { color: #fff !important; background: rgba(239,68,68,0.2); }
        .ei-navbar .user-email {
            color: rgba(255,255,255,0.6) !important; font-size: 0.82rem;
            display: flex; align-items: center; gap: 5px; padding: 0.5rem 0.9rem !important;
        }

        /* CARDS */
        .card {
            border: 1px solid var(--ei-card-border); border-radius: var(--ei-radius);
            box-shadow: var(--ei-shadow); transition: box-shadow 0.2s, transform 0.2s;
        }
        .card:hover { box-shadow: var(--ei-shadow-hover); }
        .card-header { border-radius: var(--ei-radius) var(--ei-radius) 0 0 !important; font-weight: 600; border-bottom: none; }
        .card-header.ei-header-primary {
            background: linear-gradient(135deg, var(--ei-navy) 0%, var(--ei-navy-light) 100%); color: #fff;
        }
        .card-header.ei-header-teal {
            background: linear-gradient(135deg, var(--ei-teal-dark) 0%, var(--ei-accent) 100%); color: #fff;
        }

        /* DASHBOARD ACTION CARDS */
        .ei-action-card { border-top: 3px solid var(--ei-teal); text-align: center; padding: 0.5rem; }
        .ei-action-card .card-icon {
            width: 56px; height: 56px; border-radius: 14px; display: flex;
            align-items: center; justify-content: center; margin: 0 auto 1rem; font-size: 1.5rem;
        }
        .icon-blue   { background: #dbeafe; color: #2563eb; }
        .icon-green  { background: #d1fae5; color: #059669; }
        .icon-amber  { background: #fef3c7; color: #d97706; }
        .icon-purple { background: #ede9fe; color: #7c3aed; }
        .icon-teal   { background: #cffafe; color: #0891b2; }
        .icon-rose   { background: #ffe4e6; color: #e11d48; }

        /* STAT CARDS */
        .ei-stat-card { border-left: 4px solid var(--ei-teal); }
        .ei-stat-value { font-size: 2rem; font-weight: 700; line-height: 1; }

        /* TABLES */
        .ei-table { border-radius: var(--ei-radius); overflow: hidden; border: 1px solid var(--ei-card-border); }
        .ei-table thead { background: linear-gradient(135deg, var(--ei-navy) 0%, var(--ei-navy-light) 100%); color: #fff; }
        .ei-table thead th { font-weight: 600; font-size: 0.8rem; letter-spacing: 0.5px; text-transform: uppercase; border: none; padding: 0.85rem 1rem; }
        .ei-table tbody tr { border-bottom: 1px solid #f1f5f9; transition: background 0.15s; }
        .ei-table tbody tr:hover { background: #f0f9ff; }
        .ei-table tbody td { padding: 0.75rem 1rem; vertical-align: middle; border: none; font-size: 0.9rem; }
        .ei-table tbody tr:last-child { border-bottom: none; }

        /* FORMS */
        .form-control, .form-select {
            border-radius: 8px; border: 1.5px solid #e2e8f0; padding: 0.55rem 0.85rem;
            font-size: 0.9rem; transition: border-color 0.2s, box-shadow 0.2s;
        }
        .form-control:focus, .form-select:focus {
            border-color: var(--ei-teal); box-shadow: 0 0 0 3px rgba(14,165,233,0.15);
        }
        .form-label, label { font-weight: 500; font-size: 0.875rem; color: #374151; margin-bottom: 0.4rem; }

        /* BUTTONS */
        .btn { border-radius: 8px; font-weight: 500; font-size: 0.875rem; padding: 0.5rem 1.1rem; transition: all 0.2s; }
        .btn-primary { background: linear-gradient(135deg, var(--ei-teal-dark), var(--ei-accent)); border: none; color: #fff; }
        .btn-primary:hover { background: linear-gradient(135deg, #026ea8, var(--ei-teal-dark)); transform: translateY(-1px); box-shadow: 0 4px 12px rgba(2,132,199,0.35); }
        .btn-success { background: linear-gradient(135deg, #059669, var(--ei-success)); border: none; }
        .btn-success:hover { transform: translateY(-1px); box-shadow: 0 4px 12px rgba(16,185,129,0.35); }
        .btn-warning { background: linear-gradient(135deg, #d97706, var(--ei-warning)); border: none; color: #fff; }
        .btn-warning:hover { color: #fff; transform: translateY(-1px); }
        .btn-danger { border-radius: 8px; }
        .btn-secondary { background: #f1f5f9; border: 1.5px solid #e2e8f0; color: #475569; }
        .btn-secondary:hover { background: #e2e8f0; color: #334155; }
        .btn-info { background: linear-gradient(135deg, #0891b2, var(--ei-accent)); border: none; color: #fff; }
        .btn-info:hover { color: #fff; transform: translateY(-1px); }
        .btn-dark { background: linear-gradient(135deg, var(--ei-navy), var(--ei-navy-light)); border: none; }
        .btn-outline-primary { border-color: var(--ei-teal-dark); color: var(--ei-teal-dark); }
        .btn-outline-primary:hover { background: var(--ei-teal-dark); border-color: var(--ei-teal-dark); }

        /* PAGE HEADER */
        .ei-page-header { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1.5rem; }
        .ei-page-header h2 { font-size: 1.5rem; font-weight: 700; color: var(--ei-navy); margin: 0; }
        .ei-page-header .header-icon {
            width: 42px; height: 42px; background: linear-gradient(135deg, var(--ei-teal-dark), var(--ei-accent));
            border-radius: 10px; display: flex; align-items: center; justify-content: center;
            color: #fff; font-size: 1.1rem; flex-shrink: 0;
        }

        /* ALERTS */
        .alert { border-radius: 10px; font-size: 0.9rem; border: none; }
        .alert-info { background: #e0f2fe; color: #0369a1; }
        .alert-success { background: #d1fae5; color: #065f46; }
        .alert-danger { background: #fee2e2; color: #991b1b; }
        .alert-warning { background: #fef3c7; color: #92400e; }

        /* PAGINATION */
        .page-link { border-radius: 8px !important; margin: 0 2px; border: 1.5px solid #e2e8f0; color: var(--ei-navy); font-size: 0.85rem; font-weight: 500; }
        .page-item.active .page-link { background: linear-gradient(135deg, var(--ei-teal-dark), var(--ei-accent)); border-color: transparent; }
        .page-link:hover { background: #f0f9ff; border-color: var(--ei-teal); color: var(--ei-teal-dark); }

        /* BADGE */
        .badge { border-radius: 6px; font-weight: 500; }

        /* FOOTER */
        .ei-footer {
            background: linear-gradient(135deg, var(--ei-navy) 0%, var(--ei-navy-light) 100%);
            color: rgba(255,255,255,0.55); font-size: 0.8rem; padding: 1.2rem 0;
        }

        /* WELCOME BANNER */
        .ei-welcome {
            background: linear-gradient(135deg, var(--ei-navy) 0%, var(--ei-navy-light) 60%, var(--ei-teal-dark) 100%);
            color: #fff; border-radius: var(--ei-radius); padding: 2rem; margin-bottom: 1.5rem;
        }

        /* POLICY CARD */
        .ei-policy-header {
            background: linear-gradient(135deg, var(--ei-navy), var(--ei-navy-light));
            border-radius: var(--ei-radius) var(--ei-radius) 0 0; color: #fff;
            padding: 1rem 1.25rem; display: flex; justify-content: space-between; align-items: center;
        }
    </style>
</head>

<body>

    <!-- NAVBAR -->
    <header>
        <nav class="navbar navbar-expand-lg ei-navbar">
            <div class="container-fluid">
                <a class="navbar-brand" href="@Url.Action("RedirectDashboard", "Account")">
                    <i class="bi bi-shield-check"></i> EInsurance
                </a>
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarContent">
                    <ul class="navbar-nav me-auto gap-1">
                        @if (role == "Customer")
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="Customer" asp-action="Dashboard"><i class="bi bi-speedometer2 me-1"></i>Dashboard</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Customer" asp-action="MyPolicies"><i class="bi bi-file-earmark-text me-1"></i>My Policies</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Customer" asp-action="AvailablePolicies"><i class="bi bi-cart-plus me-1"></i>Buy Policy</a></li>
                        }
                        @if (role == "Agent")
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="Agent" asp-action="Dashboard"><i class="bi bi-speedometer2 me-1"></i>Dashboard</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Agent" asp-action="Customers"><i class="bi bi-people me-1"></i>Customers</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Agent" asp-action="CommissionHistory"><i class="bi bi-cash-coin me-1"></i>Commission</a></li>
                        }
                        @if (role == "Admin")
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="Admin" asp-action="Dashboard"><i class="bi bi-speedometer2 me-1"></i>Dashboard</a></li>
                        }
                        @if (role == "Employee")
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="Employee" asp-action="Dashboard"><i class="bi bi-speedometer2 me-1"></i>Dashboard</a></li>
                        }
                    </ul>
                    <ul class="navbar-nav ms-auto gap-1">

    @{
        var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    }

    @if (!string.IsNullOrEmpty(email))
    {
        <!-- Logged In -->
        <li class="nav-item">
            <span class="nav-link user-email">
                <i class="bi bi-person-circle"></i> @email
            </span>
        </li>
        <li class="nav-item">
            <a class="nav-link text-danger" asp-controller="Account" asp-action="Logout">
                <i class="bi bi-box-arrow-right me-1"></i> Logout
            </a>
        </li>
    }
    else
    {

        @* If user is on Login page → show Register *@
        @if (currentController == "Account" && currentAction == "Login")
        {
            <li class="nav-item">
                <a class="nav-link @(currentAction == "Register" ? "active" : "")"
                   asp-controller="Account" asp-action="Register">
                    <i class="bi bi-person-plus me-1"></i> Register
                </a>
            </li>
        }
        else
        {
            <li class="nav-item">
                <a class="nav-link @(currentAction == "Login" ? "active" : "")"
                   asp-controller="Account" asp-action="Login">
                    <i class="bi bi-box-arrow-in-right me-1"></i> Login
                </a>
            </li>
        }
    }
</ul>
                </div>
            </div>
        </nav>
    </header>

    <!-- MAIN CONTENT -->
    <div class="container mt-4">
        <main role="main" class="pb-4">
            @RenderBody()
        </main>
    </div>

    <!-- FOOTER -->
    <footer class="ei-footer">
        <div class="container text-center">
            <i class="bi bi-shield-check me-1"></i>
            &copy; 2026 EInsurance System &mdash; All rights reserved
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
